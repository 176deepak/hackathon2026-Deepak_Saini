# Compose-level variables used by docker-compose.yml

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shopwave
REDIS_PASSWORD=redispass

# Backend service env file path (relative to repository root)
BACKEND_ENV_FILE=./backend/.env.docker

# Frontend build-time variables
VITE_API_BASE_URL=http://localhost:8000
VITE_API_VERSION=1