ENVIRONMENT=local

APP_NAME=Resolvr
APP_DESCRIPTION=Autonomous Support Resolution Agent
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-secret
APP_LOG_LEVEL=INFO
APP_LOG_COLOR=true
APP_LOGS_DIR=LOGS
APP_JWT_ALGORITHM=HS256
APP_JWT_SECRET_KEY=change-this-jwt-secret
APP_JWT_EXP_TIME=60
APP_BASE_URL=http://localhost:8000
APP_DOCS_USERNAME=admin
APP_DOCS_PASSWORD=admin
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=admin
APP_SUPPORT_EMAIL=support@shopwave.com
APP_SCHEDULER_MAX_INSTANCE=2
APP_APIS_VERSION=1

PG_DB_HOST=localhost
PG_DB_PORT=5432
PG_DB_USER=postgres
PG_DB_PASSWORD=postgres
PG_DB_NAME=shopwave
PG_MIN_CONNECTION=5
PG_MAX_CONNECTION=10
PG_DEFAULT_PAGE=1
PG_DEFAULT_PAGINATION=20
PG_DEFAULT_MAX_LIMIT=100

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=redispass
REDIS_DB=0

AGENT_AUTORUN=true
AGENT_POLL_SECONDS=30
AGENT_MAX_CONCURRENCY=8
AGENT_MAX_TICKETS_PER_TICK=20
AGENT_MAX_RETRIES=2
AGENT_LLM_MAX_RETRIES=4
AGENT_LLM_MAX_CONCURRENCY=2
AGENT_LLM_MIN_DELAY_SECONDS=0.4
AGENT_LLM_MAX_DELAY_SECONDS=1.2
AGENT_LLM_BACKOFF_MAX_SECONDS=20.0
AGENT_FAULT_INJECTION=true
AGENT_DRAW_GRAPH=false

HISTORY_TTL=3600
HISTORY_TTL_REFRESH_ON_READ=true

LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

WHICH_KNOWLEDGE_BASE=local
VECTOR_DB_NAME=shopwave_kb
CHUNK_SIZE=800
CHUNK_OVERLAP=120
KNOWLEDGE_BASE_GDRIVE_FILE_ID=
EMBEDDING_MODEL=models/embedding-001
NO_TOP_K_CHUNKS=8
NO_TOP_N_CHUNKS=4
KNOWLEDGE_BASE_UPLOAD_DIR=uploads
