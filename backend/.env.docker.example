ENVIRONMENT=local

APP_NAME=Resolvr
APP_DESCRIPTION=Autonomous Support Resolution Agent
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-secret
APP_LOG_LEVEL=INFO
APP_LOG_COLOR=true
APP_LOGS_DIR=LOGS
APP_JWT_ALGORITHM=HS256
APP_JWT_SECRET_KEY=change-this-jwt-secret
APP_JWT_EXP_TIME=86400
APP_BASE_URL=http://localhost:8000
APP_DOCS_USERNAME=admin
APP_DOCS_PASSWORD=admin
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=admin
APP_SUPPORT_EMAIL=support@shopwave.com
APP_SCHEDULER_MAX_INSTANCE=3
APP_APIS_VERSION=1

PG_DB_HOST=postgres
PG_DB_PORT=5432
PG_DB_USER=postgres
PG_DB_PASSWORD=postgres
PG_DB_NAME=shopwave
PG_MIN_CONNECTION=5
PG_MAX_CONNECTION=20
PG_DEFAULT_PAGE=1
PG_DEFAULT_PAGINATION=20
PG_DEFAULT_MAX_LIMIT=100

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=redispass
REDIS_DB=0

AGENT_AUTORUN=true
AGENT_POLL_SECONDS=120
AGENT_MAX_CONCURRENCY=2
AGENT_MAX_TICKETS_PER_TICK=5
AGENT_MAX_RETRIES=1
AGENT_LLM_MAX_RETRIES=3
AGENT_LLM_MAX_CONCURRENCY=1
AGENT_LLM_MIN_DELAY_SECONDS=5
AGENT_LLM_MAX_DELAY_SECONDS=10
AGENT_LLM_BACKOFF_MAX_SECONDS=45.0
AGENT_FAULT_INJECTION=false
AGENT_DRAW_GRAPH=false

HISTORY_TTL=3600
HISTORY_TTL_REFRESH_ON_READ=true

LLM_PROVIDER=groq
LLM_MODEL=llama3-groq-tool-use
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

WHICH_KNOWLEDGE_BASE=chroma
VECTOR_DB_NAME=shopwave
CHUNK_SIZE=750
CHUNK_OVERLAP=150
KNOWLEDGE_BASE_GDRIVE_FILE_ID=
EMBEDDING_MODEL=gemini-embedding-001
NO_TOP_K_CHUNKS=15
NO_TOP_N_CHUNKS=5
KNOWLEDGE_BASE_UPLOAD_DIR=uploads
